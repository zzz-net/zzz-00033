{
  "batch_name": "codex-review-main-json-a03-20260612114505",
  "root_alias": "交付资料包",
  "expiry_date": "2026-01-01",
  "ignore_patterns": [
    "**/.git/**",
    "**/__pycache__/**",
    "**/node_modules/**",
    "**/*.log",
    "**/Thumbs.db",
    "**/.DS_Store"
  ],
  "required_files": [
    {
      "pattern": "README.md",
      "description": "项目说明文档"
    },
    {
      "pattern": "docs/**/*.md",
      "description": "设计与需求文档（至少一个）"
    },
    {
      "pattern": "docs/requirements.docx",
      "description": "签字版需求文档（非可选）",
      "naming_rule": "signature-doc",
      "expiry_date": "2026-06-01"
    },
    {
      "pattern": "src/**/*.py",
      "description": "Python 源码目录（必需）"
    },
    {
      "pattern": "tests/**/*.py",
      "description": "单元测试文件",
      "optional": true
    },
    {
      "pattern": "build/report*.pdf",
      "description": "最终交付测试报告",
      "naming_rule": "report-date"
    },
    {
      "pattern": "config/config.yaml",
      "description": "部署配置模板"
    },
    {
      "pattern": "CHANGELOG.md",
      "description": "版本变更记录"
    },
    {
      "pattern": "deliverables/slot_*.txt",
      "description": "交付槽位文件（仅允许 1 份）",
      "max_matches": 1
    }
  ],
  "naming_rules": [
    {
      "name": "signature-doc",
      "pattern": "docs/requirements.docx",
      "regex": "^requirements_(v\\d{4}\\.\\d{2})_签字版\\.docx$",
      "description": "文件名必须形如 requirements_v2026.02_签字版.docx"
    },
    {
      "name": "report-date",
      "pattern": "build/report*.pdf",
      "regex": "^test_report_(\\d{8})\\.pdf$",
      "description": "文件名必须形如 test_report_20260612.pdf"
    }
  ],
  "metadata": {
    "client": "示例客户",
    "project": "交付样例项目",
    "version": "1.0.0",
    "owner": "交付组"
  }
}
